<Window x:Class="PedestrianCrossing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симулятор пешеходного перехода (WPF MVVM)" Height="700" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
            <Button Content="Добавить Авто" Click="AddModel_Click" 
                    Tag="PedestrianCrossing.Models.Car" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="Добавить Пешехода" Click="AddModel_Click" 
                    Tag="PedestrianCrossing.Models.Pedestrian" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="▶ Запуск" Click="Start_Click" Margin="0,0,10,0" Padding="10,5" Background="LightGreen"/>
            <Button Content="⏹ Стоп" Click="Stop_Click" Padding="10,5" Background="LightCoral"/>
        </StackPanel>

        <Canvas x:Name="SimulationCanvas" Grid.Row="1" Background="LightGray" Margin="10" ClipToBounds="True">
            <Rectangle Canvas.Left="0" Canvas.Top="270" Width="800" Height="60" Fill="DarkGray"/>
            <Rectangle Canvas.Left="350" Canvas.Top="200" Width="100" Height="200" Fill="White" Opacity="0.7"/>
        </Canvas>

        <TextBlock x:Name="LightTextBlock" Grid.Row="2" Text="Светофор: 🟢 Машинам" 
                   FontSize="16" FontWeight="Bold" Foreground="Green" Margin="10" HorizontalAlignment="Left"/>
    </Grid>
</Window>