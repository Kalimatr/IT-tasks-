<Window x:Class="AircraftWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление летательными аппаратами" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:MainViewModel xmlns:local="clr-namespace:AircraftWpfApp"/>
    </Window.DataContext>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Путь:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="{Binding AssemblyPath, UpdateSourceTrigger=PropertyChanged}" Width="600" Margin="0,0,10,0"/>
            <Button Content="Загрузить" Command="{Binding LoadAssemblyCommand}" Padding="15,5" FontWeight="Bold"/>
        </StackPanel>

        <!-- КОЛОНКА 1: Создание -->
        <GroupBox Grid.Row="1" Grid.Column="0" Header="1. Создание объекта" Margin="0,0,10,0">
            <StackPanel>
                <TextBlock Text="Класс:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding ClassNames}" SelectedItem="{Binding SelectedClassName}" Height="80" Margin="0,0,0,15"/>

                <TextBlock Text="Параметры конструктора:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ConstructorParams}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,5">
                                    <TextBlock Text="{Binding Name}" Width="120" VerticalAlignment="Center"/>
                                    <TextBlock Text="(" Foreground="Gray"/><TextBlock Text="{Binding TypeName}" Foreground="Gray"/><TextBlock Text="):" Foreground="Gray"/>
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="5,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Content="Создать объект" Command="{Binding CreateObjectCommand}" Margin="0,15,0,0" Padding="10" Background="#E0F7FA" FontWeight="Bold" FontSize="14"/>
            </StackPanel>
        </GroupBox>

        <!-- КОЛОНКА 2: Список созданных объектов -->
        <GroupBox Grid.Row="1" Grid.Column="1" Header="2. Созданные объекты" Margin="10,0,10,0">
            <ListBox ItemsSource="{Binding CreatedObjects}" SelectedItem="{Binding SelectedObject}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="#007ACC"/>
                            <TextBlock Text="{Binding StateInfo}" Foreground="#333" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- КОЛОНКА 3: Управление -->
        <GroupBox Grid.Row="1" Grid.Column="2" Header="3. Управление объектом" Margin="10,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="Выбран:" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedObject.DisplayName}" FontSize="16" Foreground="#007ACC"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Методы" Margin="0,0,10,0">
                        <ListBox ItemsSource="{Binding Methods}" SelectedItem="{Binding SelectedMethod}">
                            <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}" FontWeight="Bold"/></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Параметры метода">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding SelectedMethod.Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,5">
                                            <TextBlock Text="{Binding Name}" Width="120" VerticalAlignment="Center"/>
                                            <TextBlock Text="(" Foreground="Gray"/><TextBlock Text="{Binding TypeName}" Foreground="Gray"/><TextBlock Text="):" Foreground="Gray"/>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="5,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBox Grid.Row="0" Text="{Binding Log, Mode=OneWay}" IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Background="#F9F9F9"/>
                    <Button Grid.Row="1" Content="Выполнить метод" Command="{Binding ExecuteMethodCommand}" HorizontalAlignment="Right" Padding="20,10" Margin="0,10,0,0" FontSize="14" FontWeight="Bold" Background="#E8F5E9"/>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</Window>